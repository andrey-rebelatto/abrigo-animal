---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import biscoitoImg from '../assets/biscoito.png';
import cajuImg from '../assets/caju.png';
import melImg from '../assets/mel.png';
import pipocaImg from '../assets/pipoca.png';
import fachadaImg from '../assets/fachada-abrigo.jpg';
---

<Layout title="Abrigo Animal | Joinville SC">

  <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
  <section class="bg-[#F2EFE8] px-5 pt-8 pb-12 lg:pt-16 lg:pb-20">
    <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[1fr_420px] lg:gap-16 lg:items-center">

      <!-- Texto -->
      <div class="flex flex-col gap-6">
        <!-- Eyebrow -->
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#6F8B5A] shrink-0"></span>
          <span class="text-xs font-semibold tracking-[0.14em] uppercase text-[#6F8B5A]"
                style="font-family: var(--font-body)">Quem já encontrou um lar</span>
        </div>

        <!-- Headline -->
        <h1 class="text-[40px] leading-[1.1] font-semibold tracking-[-0.02em] text-[#2A332F] lg:text-6xl"
            style="font-family: var(--font-display); text-wrap: balance">
          Esse é o Biscoito.<br />Ficou 3 anos esperando. Hoje tem quintal.
        </h1>

        <!-- Foto — mobile only (aparece entre headline e copy) -->
        <div class="lg:hidden relative w-full aspect-[4/4.5] rounded-3xl overflow-hidden"
             style="box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1)">
          <Image src={biscoitoImg} alt="Biscoito, cão malhado rolando na grama feliz após ser adotado"
                 class="absolute inset-0 w-full h-full object-cover object-center" />
          <div class="absolute bottom-5 left-5 flex gap-2">
            <span class="rounded-full py-1.5 px-3 bg-[#FCFAF3]/92 text-xs font-semibold text-[#2A332F]"
                  style="font-family: var(--font-body)">SRD macho</span>
            <span class="rounded-full py-1.5 px-3 bg-[#FCFAF3]/92 text-xs font-semibold text-[#2A332F]"
                  style="font-family: var(--font-body)">Adotado em 2024</span>
            <span class="rounded-full py-1.5 px-3 bg-[#FCFAF3]/92 text-xs font-semibold text-[#2A332F]"
                  style="font-family: var(--font-body)">Joinville</span>
          </div>
        </div>

        <!-- Copy -->
        <p class="text-[17px] leading-6.5 text-[#2A332F]/82 lg:text-lg lg:max-w-xl"
           style="font-family: var(--font-body); text-wrap: pretty">
          Ficou três anos esperando. Hoje brinca com as crianças no quintal da Luciana e do Pedro — e já sabe exatamente o que é uma casa.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col gap-3 lg:flex-row">
          <a href="/adote"
             class="flex justify-center items-center rounded-full py-4 px-7 bg-[#2A332F] text-[#FCFAF3] text-base font-semibold hover:bg-[#3A4A34] transition-colors"
             style="font-family: var(--font-body)">
            Adote seu melhor amigo
          </a>
          <a href="/ajudar"
             class="flex justify-center items-center rounded-full py-4 px-7 border-[1.5px] border-[#2A332F]/24 text-[#2A332F] text-base font-medium hover:bg-[#2A332F]/5 transition-colors"
             style="font-family: var(--font-body)">
            Quero ajudar de outra forma
          </a>
        </div>
      </div>

      <!-- Foto — desktop only -->
      <div class="hidden lg:block relative w-full aspect-square rounded-3xl overflow-hidden"
           style="box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1)">
        <Image src={biscoitoImg} alt="Biscoito, cão malhado rolando na grama feliz após ser adotado"
               class="absolute inset-0 w-full h-full object-cover object-center" />
        <div class="absolute bottom-6 left-6 flex gap-2">
          <span class="rounded-full py-1.5 px-3 bg-[#FCFAF3]/92 text-xs font-semibold text-[#2A332F]"
                style="font-family: var(--font-body)">SRD macho</span>
          <span class="rounded-full py-1.5 px-3 bg-[#FCFAF3]/92 text-xs font-semibold text-[#2A332F]"
                style="font-family: var(--font-body)">Porte médio</span>
          <span class="rounded-full py-1.5 px-3 bg-[#FCFAF3]/92 text-xs font-semibold text-[#2A332F]"
                style="font-family: var(--font-body)">2 anos</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── STATS BAND ────────────────────────────────────────────────────── -->
  <section class="bg-[#FCFAF3] px-5 py-8 lg:py-12">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[#6F8B5A] mb-4"
         style="font-family: var(--font-body)">Desde 1998</p>
      <div class="flex gap-8 lg:gap-16">
        <div class="flex flex-col gap-1">
          <span class="text-4xl font-semibold tracking-[-0.02em] text-[#6F8B5A] [font-variant-numeric:tabular-nums]"
                style="font-family: var(--font-display)">234</span>
          <span class="text-[13px] leading-4.5 text-[#2A332F]/72"
                style="font-family: var(--font-body)">animais<br />adotados</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-4xl font-semibold tracking-[-0.02em] text-[#3A4A34] [font-variant-numeric:tabular-nums]"
                style="font-family: var(--font-display)">40+</span>
          <span class="text-[13px] leading-4.5 text-[#2A332F]/72"
                style="font-family: var(--font-body)">voluntários<br />ativos</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-4xl font-semibold tracking-[-0.02em] text-[#D1A24C] [font-variant-numeric:tabular-nums]"
                style="font-family: var(--font-display)">12</span>
          <span class="text-[13px] leading-4.5 text-[#2A332F]/72"
                style="font-family: var(--font-body)">sendo<br />apadrinhados</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── WAYS TO HELP ─────────────────────────────────────────────────── -->
  <section class="bg-[#F2EFE8] px-5 pt-12 pb-10 lg:pt-20 lg:pb-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-2 mb-6">
        <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[#6F8B5A]"
           style="font-family: var(--font-body)">Como ajudar</p>
        <h2 class="text-[28px] leading-8 font-semibold tracking-[-0.02em] text-[#2A332F] lg:text-4xl"
            style="font-family: var(--font-display); text-wrap: balance">
          Quatro formas de mudar uma história.
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- Adotar -->
        <div class="flex flex-col gap-4 rounded-[20px] bg-[#FCFAF3] border border-[#2A332F]/8 p-6">
          <div class="flex items-center justify-center w-12 h-12 rounded-[14px] bg-[#6F8B5A] shrink-0">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 2C6.03 2 2 6.03 2 11s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 4c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 12.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" fill="#FCFAF3"/>
            </svg>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-[22px] leading-6.5 font-semibold tracking-[-0.01em] text-[#2A332F]"
                style="font-family: var(--font-display)">Adotar um animal</h3>
            <p class="text-[15px] leading-5.5 text-[#2A332F]/72"
               style="font-family: var(--font-body)">
              Venha visitar e encontrar seu companheiro. Todos vacinados e castrados.
            </p>
          </div>
          <a href="/contato" class="flex items-center gap-2 pt-2 text-sm font-semibold text-[#3A4A34] hover:text-[#6F8B5A] transition-colors"
             style="font-family: var(--font-body)">
            Agendar uma visita
            <span class="w-4 h-4 rounded-sm bg-[#3A4A34]/30 inline-block"></span>
          </a>
        </div>

        <!-- Apadrinhar -->
        <div class="flex flex-col gap-4 rounded-[20px] bg-[#FCFAF3] border border-[#2A332F]/8 p-6">
          <div class="flex items-center justify-center w-12 h-12 rounded-[14px] bg-[#3A4A34] shrink-0">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#FCFAF3"/>
            </svg>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-[22px] leading-6.5 font-semibold tracking-[-0.01em] text-[#2A332F]"
                style="font-family: var(--font-display)">Apadrinhar um cão idoso</h3>
            <p class="text-[15px] leading-5.5 text-[#2A332F]/72"
               style="font-family: var(--font-body)">
              R$ 80/mês garantem ração, remédios e a certeza de que ele não passa frio.
            </p>
          </div>
          <a href="/caofilhado" class="flex items-center gap-2 pt-2 text-sm font-semibold text-[#3A4A34] hover:text-[#6F8B5A] transition-colors"
             style="font-family: var(--font-body)">
            Conhecer o projeto Cãofilhado
            <span class="w-4 h-4 rounded-sm bg-[#3A4A34]/30 inline-block"></span>
          </a>
        </div>

        <!-- Doar -->
        <div class="flex flex-col gap-4 rounded-[20px] bg-[#FCFAF3] border border-[#2A332F]/8 p-6">
          <div class="flex items-center justify-center w-12 h-12 rounded-[14px] bg-[#D1A24C] shrink-0">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 2C6.48 2 2 6.48 2 11s4.48 9 9 9 9-4.48 9-9-4.48-9-9-9zm1 14H10v-2h2v2zm0-4H10V6h2v6z" fill="#FCFAF3"/>
            </svg>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-[22px] leading-6.5 font-semibold tracking-[-0.01em] text-[#2A332F]"
                style="font-family: var(--font-display)">Doar via PIX</h3>
            <p class="text-[15px] leading-5.5 text-[#2A332F]/72"
               style="font-family: var(--font-body)">
              Qualquer valor vira ração, vacina ou castração. CNPJ e recibo emitidos.
            </p>
          </div>
          <a href="/ajudar" class="flex items-center gap-2 pt-2 text-sm font-semibold text-[#8E6F24] hover:text-[#D1A24C] transition-colors"
             style="font-family: var(--font-body)">
            Ver formas de doação
            <span class="w-4 h-4 rounded-sm bg-[#8E6F24]/30 inline-block"></span>
          </a>
        </div>

        <!-- Voluntariar -->
        <div class="flex flex-col gap-4 rounded-[20px] bg-[#FCFAF3] border border-[#2A332F]/8 p-6">
          <div class="flex items-center justify-center w-12 h-12 rounded-[14px] bg-[#B5C4A6] shrink-0">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09C10.91 3.81 9.24 3 7.5 3 4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3z" fill="#FCFAF3"/>
            </svg>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-[22px] leading-6.5 font-semibold tracking-[-0.01em] text-[#2A332F]"
                style="font-family: var(--font-display)">Ser voluntário</h3>
            <p class="text-[15px] leading-5.5 text-[#2A332F]/72"
               style="font-family: var(--font-body)">
              Passear, dar banho, levar ao veterinário. Uma tarde por mês já ajuda muito.
            </p>
          </div>
          <a href="/contato" class="flex items-center gap-2 pt-2 text-sm font-semibold text-[#3A4A34] hover:text-[#6F8B5A] transition-colors"
             style="font-family: var(--font-body)">
            Cadastrar disponibilidade
            <span class="w-4 h-4 rounded-sm bg-[#3A4A34]/30 inline-block"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ADOPTION STORIES ──────────────────────────────────────────────── -->
  <section class="bg-[#FCFAF3] pt-12 pb-10 lg:pt-20 lg:pb-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-2 mb-6 px-5">
        <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[#6F8B5A]"
           style="font-family: var(--font-body)">Quem já achou um lar</p>
        <h2 class="text-[28px] leading-8 font-semibold tracking-[-0.02em] text-[#2A332F] lg:text-4xl"
            style="font-family: var(--font-display); text-wrap: balance">
          Algumas histórias que já terminaram bem.
        </h2>
      </div>

      <!-- Mobile: scroll horizontal / Desktop: 3 colunas -->
      <div class="flex gap-4 px-5 overflow-x-auto snap-x snap-mandatory pb-2
                  lg:overflow-visible lg:grid lg:grid-cols-3 lg:pb-0">
        <!-- Card 1 -->
        <article class="flex flex-col w-64 shrink-0 snap-start rounded-[20px] overflow-hidden bg-[#F2EFE8]
                        lg:w-auto lg:shrink lg:snap-align-none">
          <div class="h-48 shrink-0 relative overflow-hidden">
            <Image src={melImg} alt="Mel, gatinha preta e branca com gravata borboleta"
                   class="absolute inset-0 w-full h-full object-cover object-center" />
          </div>
          <div class="flex flex-col gap-2.5 p-5">
            <div class="flex items-center gap-2">
              <span class="text-lg font-semibold text-[#2A332F]"
                    style="font-family: var(--font-display)">Mel</span>
              <span class="w-1 h-1 rounded-full bg-[#2A332F]/30 shrink-0"></span>
              <span class="text-[13px] text-[#2A332F]/60" style="font-family: var(--font-body)">adotada em 2025</span>
            </div>
            <p class="text-sm leading-5.25 text-[#2A332F]/76" style="font-family: var(--font-body)">
              "Ela dormiu na nossa cama na primeira noite. Nunca mais saiu."
            </p>
            <p class="text-xs text-[#2A332F]/50" style="font-family: var(--font-body)">— Família Oliveira</p>
          </div>
        </article>

        <!-- Card 2 -->
        <article class="flex flex-col w-64 shrink-0 snap-start rounded-[20px] overflow-hidden bg-[#F2EFE8]
                        lg:w-auto lg:shrink lg:snap-align-none">
          <div class="h-48 shrink-0 relative overflow-hidden">
            <Image src={cajuImg} alt="Caju, cão preto sentado na grama com a língua de fora"
                   class="absolute inset-0 w-full h-full object-cover object-center" />
          </div>
          <div class="flex flex-col gap-2.5 p-5">
            <div class="flex items-center gap-2">
              <span class="text-lg font-semibold text-[#2A332F]"
                    style="font-family: var(--font-display)">Caju</span>
              <span class="w-1 h-1 rounded-full bg-[#2A332F]/30 shrink-0"></span>
              <span class="text-[13px] text-[#2A332F]/60" style="font-family: var(--font-body)">adotado em 2024</span>
            </div>
            <p class="text-sm leading-5.25 text-[#2A332F]/76" style="font-family: var(--font-body)">
              "Chegou tremendo, não deixava ninguém se aproximar. Hoje dorme na cama do meu filho todo dia."
            </p>
            <p class="text-xs text-[#2A332F]/50" style="font-family: var(--font-body)">— Mariana S.</p>
          </div>
        </article>

        <!-- Card 3 -->
        <article class="flex flex-col w-64 shrink-0 snap-start rounded-[20px] overflow-hidden bg-[#F2EFE8]
                        lg:w-auto lg:shrink lg:snap-align-none">
          <div class="h-48 shrink-0 relative overflow-hidden">
            <Image src={pipocaImg} alt="Pipoca, gata branca com olhos azuis"
                   class="absolute inset-0 w-full h-full object-cover object-center" />
          </div>
          <div class="flex flex-col gap-2.5 p-5">
            <div class="flex items-center gap-2">
              <span class="text-lg font-semibold text-[#2A332F]"
                    style="font-family: var(--font-display)">Pipoca</span>
              <span class="w-1 h-1 rounded-full bg-[#2A332F]/30 shrink-0"></span>
              <span class="text-[13px] text-[#2A332F]/60" style="font-family: var(--font-body)">adotada em 2023</span>
            </div>
            <p class="text-sm leading-5.25 text-[#2A332F]/76" style="font-family: var(--font-body)">
              "Tinha medo de tudo. Hoje mia pra carteiro como se sempre tivesse sido dona do lugar."
            </p>
            <p class="text-xs text-[#2A332F]/50" style="font-family: var(--font-body)">— Carolina M.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ─── ABOUT TEASER ─────────────────────────────────────────────────── -->
  <section class="bg-[#F2EFE8] px-5 pt-12 pb-10 lg:pt-20 lg:pb-16">
    <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[2fr_3fr] lg:gap-14 lg:items-center">
      <!-- Foto -->
      <div class="w-full aspect-video rounded-[20px] mb-6 lg:mb-0 lg:aspect-[4/3] relative overflow-hidden"
           style="box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1)">
        <Image src={fachadaImg} alt="Fachada do Abrigo Animal de Joinville, paredes verdes com pegadas pintadas"
               class="absolute inset-0 w-full h-full object-cover object-center" />
      </div>
      <!-- Texto -->
      <div class="flex flex-col gap-4">
        <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[#6F8B5A]"
           style="font-family: var(--font-body)">Quem somos</p>
        <h2 class="text-[28px] leading-8 font-semibold tracking-[-0.02em] text-[#2A332F] lg:text-4xl"
            style="font-family: var(--font-display); text-wrap: balance">
          Uma associação sem fins lucrativos. 28 anos.
        </h2>
        <p class="text-base leading-6 text-[#2A332F]/78" style="font-family: var(--font-body)">
          Começamos com três pessoas e um canil improvisado. Hoje abrigamos 58 animais, com veterinário próprio e mais de 40 voluntários ativos. Tudo movido a doação.
        </p>
        <a href="/sobre"
           class="flex items-center gap-2 pt-1 text-[15px] font-semibold text-[#6F8B5A] hover:text-[#3A4A34] underline underline-offset-4 decoration-1 transition-colors w-fit"
           style="font-family: var(--font-body)">
          Conhecer a história completa
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────────────────── -->
  <section class="bg-[#FCFAF3] px-5 pt-10 pb-10 lg:pt-16 lg:pb-16">
    <div class="mx-auto max-w-7xl lg:max-w-3xl">
      <div class="flex flex-col gap-2 mb-6">
        <p class="text-xs font-semibold tracking-[0.14em] uppercase text-[#6F8B5A]"
           style="font-family: var(--font-body)">Perguntas comuns</p>
        <h2 class="text-[28px] leading-8 font-semibold tracking-[-0.02em] text-[#2A332F]"
            style="font-family: var(--font-display)">
          As três que mais recebemos.
        </h2>
      </div>

      <div class="flex flex-col gap-3">
        <details class="group rounded-2xl bg-[#F2EFE8] border border-[#2A332F]/8 p-5 open:pb-5" open>
          <summary class="flex justify-between items-center gap-3 cursor-pointer list-none">
            <h3 class="text-lg font-semibold text-[#2A332F] leading-6"
                style="font-family: var(--font-display)">
              Posso visitar os animais antes de adotar?
            </h3>
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[#2A332F] shrink-0 group-open:bg-[#2A332F]/10 transition-colors">
              <svg class="group-open:hidden" width="12" height="2" viewBox="0 0 12 2" fill="none">
                <rect width="12" height="2" rx="1" fill="#FCFAF3"/>
              </svg>
              <svg class="hidden group-open:block" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <rect x="5" width="2" height="12" rx="1" fill="#2A332F"/>
                <rect y="5" width="12" height="2" rx="1" fill="#2A332F"/>
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-sm leading-5.25 text-[#2A332F]/72" style="font-family: var(--font-body)">
            Pode e deve. Visitas aos sábados e domingos, das 14h às 17h, com agendamento via WhatsApp. Assim garantimos atenção individual.
          </p>
        </details>

        <details class="group rounded-2xl bg-[#F2EFE8] border border-[#2A332F]/8 p-5">
          <summary class="flex justify-between items-center gap-3 cursor-pointer list-none">
            <h3 class="text-lg font-semibold text-[#2A332F] leading-6"
                style="font-family: var(--font-display)">
              Como funciona o processo de adoção?
            </h3>
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[#2A332F]/8 shrink-0 group-open:bg-[#2A332F] transition-colors relative">
              <svg class="group-open:hidden" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <rect x="5" width="2" height="12" rx="1" fill="#2A332F"/>
                <rect y="5" width="12" height="2" rx="1" fill="#2A332F"/>
              </svg>
              <svg class="hidden group-open:block" width="12" height="2" viewBox="0 0 12 2" fill="none">
                <rect width="12" height="2" rx="1" fill="#FCFAF3"/>
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-sm leading-5.25 text-[#2A332F]/72" style="font-family: var(--font-body)">
            Você visita, conversa com a equipe, preenche um formulário e agendamos uma visita domiciliar. Sem burocracia excessiva — queremos um lar, não um processo.
          </p>
        </details>

        <details class="group rounded-2xl bg-[#F2EFE8] border border-[#2A332F]/8 p-5">
          <summary class="flex justify-between items-center gap-3 cursor-pointer list-none">
            <h3 class="text-lg font-semibold text-[#2A332F] leading-6"
                style="font-family: var(--font-display)">
              Vocês atendem adotantes de fora de Joinville?
            </h3>
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[#2A332F]/8 shrink-0 group-open:bg-[#2A332F] transition-colors">
              <svg class="group-open:hidden" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <rect x="5" width="2" height="12" rx="1" fill="#2A332F"/>
                <rect y="5" width="12" height="2" rx="1" fill="#2A332F"/>
              </svg>
              <svg class="hidden group-open:block" width="12" height="2" viewBox="0 0 12 2" fill="none">
                <rect width="12" height="2" rx="1" fill="#FCFAF3"/>
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-sm leading-5.25 text-[#2A332F]/72" style="font-family: var(--font-body)">
            Analisamos caso a caso. O transporte fica por conta do adotante. Entre em contato para conversar.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- ─── CLOSING CTA ───────────────────────────────────────────────────── -->
  <section class="bg-[#6F8B5A] px-6 py-14 lg:py-20">
    <div class="mx-auto max-w-xl flex flex-col gap-5">
      <h2 class="text-[32px] leading-9 font-semibold tracking-[-0.02em] text-[#FCFAF3] lg:text-5xl"
          style="font-family: var(--font-display); text-wrap: balance">
        Um lar muda tudo.<br />Inclusive o seu.
      </h2>
      <p class="text-base leading-6 text-[#FCFAF3]/86" style="font-family: var(--font-body)">
        Se não pode adotar agora, compartilhar já ajuda — alguém da sua família pode estar pronto.
      </p>
      <div class="flex flex-col gap-2.5 pt-2 lg:flex-row">
        <a href="/adote"
           class="flex justify-center items-center rounded-full py-4 px-7 bg-[#FCFAF3] text-[#2A332F] text-base font-semibold hover:bg-white transition-colors"
           style="font-family: var(--font-body)">
          Ver quem já adotamos
        </a>
        <button onclick="navigator.share ? navigator.share({title: 'Abrigo Animal', url: location.href}) : undefined"
                class="flex justify-center items-center rounded-full py-4 px-7 border-[1.5px] border-[#FCFAF3]/48 text-[#FCFAF3] text-base font-medium hover:bg-[#FCFAF3]/10 transition-colors"
                style="font-family: var(--font-body)">
          Compartilhar o site
        </button>
      </div>
    </div>
  </section>

</Layout>
