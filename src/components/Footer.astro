---
import { Image } from 'astro:assets';
import logo from '../assets/logo-abrigo-animal.png';
---

<footer class="bg-[#2A332F] px-6 pt-10 pb-8">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col lg:flex-row lg:justify-between lg:items-start gap-8">
      <!-- Marca -->
      <div class="flex items-center gap-4">
        <Image src={logo} alt="Logo Abrigo Animal Joinville" width={48} height={48} densities={[1, 2]} class="rounded-full shrink-0" />
        <div class="flex flex-col gap-2">
          <span class="text-xl font-semibold text-[#FCFAF3]"
                style="font-family: var(--font-display)">Abrigo Animal</span>
          <span class="text-sm text-[#FCFAF3]/60" style="font-family: var(--font-body)">
            Associação sem fins lucrativos · Joinville, SC
          </span>
        </div>
      </div>

      <!-- Links -->
      <nav class="flex flex-col lg:flex-row gap-4 lg:gap-8" aria-label="Links do rodapé">
        <a href="/adote" class="text-sm text-[#FCFAF3]/70 hover:text-[#FCFAF3] transition-colors">Adote um animal</a>
        <a href="/caofilhado" class="text-sm text-[#FCFAF3]/70 hover:text-[#FCFAF3] transition-colors">Cãofilhado</a>
        <a href="/ajudar" class="text-sm text-[#FCFAF3]/70 hover:text-[#FCFAF3] transition-colors">Como ajudar</a>
        <a href="/sobre" class="text-sm text-[#FCFAF3]/70 hover:text-[#FCFAF3] transition-colors">Sobre o abrigo</a>
        <a href="/contato" class="text-sm text-[#FCFAF3]/70 hover:text-[#FCFAF3] transition-colors">Contato</a>
      </nav>
    </div>

    <div class="mt-8 pt-6 border-t border-[#FCFAF3]/10">
      <p class="text-xs text-[#FCFAF3]/42" style="font-family: var(--font-body)">
        © 2026 Abrigo Animal · CNPJ 04.603.573/0001-60
      </p>
    </div>
  </div>
</footer>
