---
---

<header class="sticky top-0 z-50 flex items-center justify-between px-5 py-4 bg-[#F2EFE8]/92 backdrop-blur-sm border-b border-[#2A332F]/8">
  <a href="/" class="flex items-center gap-3">
    <img src="/logo-abrigo-animal.png" alt="Logo Abrigo Animal Joinville" width="96" height="96" class="w-24 h-24 rounded-full shrink-0" />
    <span class="flex flex-col gap-0.5">
      <span class="text-[10px] font-semibold tracking-[0.16em] uppercase text-[#6F8B5A]"
            style="font-family: var(--font-body)">Joinville · SC</span>
      <span class="text-xl font-semibold tracking-[-0.01em] text-[#2A332F]"
            style="font-family: var(--font-display)">Abrigo Animal</span>
    </span>
  </a>

  <!-- Desktop nav -->
  <nav class="hidden lg:flex items-center gap-8" aria-label="Navegação principal">
    <a href="/adote" class="text-sm font-medium text-[#2A332F] hover:text-[#6F8B5A] transition-colors">Adote</a>
    <a href="/sobre" class="text-sm font-medium text-[#2A332F] hover:text-[#6F8B5A] transition-colors">Sobre</a>
    <a href="/caofilhado" class="text-sm font-medium text-[#2A332F] hover:text-[#6F8B5A] transition-colors">Cãofilhado</a>
    <a href="/contato" class="text-sm font-medium text-[#2A332F] hover:text-[#6F8B5A] transition-colors">Contato</a>
    <a href="/ajudar"
       class="px-5 py-2.5 rounded-full bg-[#6F8B5A] text-[#FCFAF3] text-sm font-semibold hover:bg-[#3A4A34] transition-colors">
      Quero ajudar
    </a>
  </nav>

  <!-- Mobile hamburger (decorativo) -->
  <button class="lg:hidden flex flex-col justify-center items-center w-11 h-11 rounded-full bg-[#2A332F]/6 gap-1.5"
          aria-label="Menu" aria-expanded="false">
    <span class="w-4.5 h-0.5 rounded-sm bg-[#2A332F]"></span>
    <span class="w-4.5 h-0.5 rounded-sm bg-[#2A332F]"></span>
  </button>
</header>
